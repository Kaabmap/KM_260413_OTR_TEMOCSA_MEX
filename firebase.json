{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }],
    "headers": [
      {
        "source": "/data/pointclouds/**",
        "headers": [{ "key": "Accept-Ranges", "value": "bytes" }]
      },
      {
        "source": "/potree/**",
        "headers": [{ "key": "Accept-Ranges", "value": "bytes" }]
      }
    ]
  }
}
