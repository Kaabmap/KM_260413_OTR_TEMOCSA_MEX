rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /geobim_comments/{commentId} {
      allow read: if request.auth != null;
      // userId debe coincidir con el UID del token (la app escribe siempre el UID de Auth).
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      // Propietario o admin@temocsa.com (ajusta el correo si cambia el admin).
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || request.auth.token.email == 'admin@temocsa.com');
    }

    // Catálogo de usuarios para el panel admin (solo lectura desde la app; edita en consola).
    match /app_users/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
